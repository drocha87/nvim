{
  "languageserver": {
    "go": {
      "command": "gopls",
      "rootPatterns": ["go.mod"],
      "trace.server": "verbose",
      "filetypes": ["go"]
    }
  },
  "coc.preferences.formatOnSaveFiletypes": ["css", "markdown", ".vue", "typescript"],
  "suggest.noselect": false,
  "suggest.enablePreselect": false,
  "vetur.trace.server": "verbose",
  "prettier.disableLanguages": [
    "vue"
  ]
}
